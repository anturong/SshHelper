<Window x:Class="SshHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SSH 密钥登录配置助手" Height="600" Width="1050"
        Background="#0d1117" WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <!-- 左侧面板：执行与日志 -->
        <Grid Grid.Column="0" Background="#010409">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 顶部操作栏 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15" Background="#161b22">
                <Button x:Name="BtnStart" Content="▶ 一键配置并启动" Click="BtnStart_Click"
                        Background="#3fb950" Foreground="#0d1117" FontWeight="Bold"
                        Padding="15,8" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                <Button x:Name="BtnTest" Content="⟳ 仅测试连接" Click="BtnTest_Click"
                        Background="#21262d" Foreground="#e6edf3"
                        Padding="15,8" BorderThickness="1" BorderBrush="#30363d" Cursor="Hand"/>
            </StackPanel>
            <!-- 终端日志区 -->
            <RichTextBox Grid.Row="1" x:Name="LogConsole"
                         Background="Transparent" Foreground="#e6edf3"
                         BorderThickness="0" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="13"
                         VerticalScrollBarVisibility="Auto" Margin="10">
                <FlowDocument/>
            </RichTextBox>
        </Grid>
        <!-- 右侧面板：结果与连接 -->
        <Grid Grid.Column="1" Background="#161b22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 卡片1：连接信息 -->
            <Border Grid.Row="0" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="20">
                <StackPanel>
                    <TextBlock Text="📡 连接信息" Foreground="#8b949e" FontWeight="Bold" FontSize="12" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="局域网地址" Foreground="#8b949e"/>
                        <TextBlock x:Name="TxtIp" HorizontalAlignment="Right" Foreground="#58a6ff" Cursor="Hand" MouseDown="CopyText"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="端口" Foreground="#8b949e"/>
                        <TextBlock Text="22" HorizontalAlignment="Right" Foreground="#58a6ff"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="用户名" Foreground="#8b949e"/>
                        <TextBlock x:Name="TxtUser" HorizontalAlignment="Right" Foreground="#58a6ff" Cursor="Hand" MouseDown="CopyText"/>
                    </Grid>
                </StackPanel>
            </Border>
            <!-- 卡片2：私钥管理 -->
            <Border Grid.Row="1" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="20">
                <StackPanel>
                    <TextBlock Text="🔑 私钥管理" Foreground="#8b949e" FontWeight="Bold" FontSize="12" Margin="0,0,0,15"/>
                    <Button Content="👁 显示/隐藏私钥文本" Click="ToggleKey_Click"
                            Background="#21262d" Foreground="#58a6ff" Padding="10,5"
                            BorderThickness="1" BorderBrush="#30363d" Margin="0,0,0,10" Cursor="Hand"/>

                    <TextBox x:Name="TxtPrivateKey" Visibility="Collapsed"
                             Background="#0d1117" Foreground="#d29922" IsReadOnly="True"
                             TextWrapping="Wrap" Height="100" BorderBrush="#30363d"
                             FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>

                    <Button Content="📋 复制私钥文本" Click="CopyKeyText_Click"
                            Background="#21262d" Foreground="#3fb950" Padding="10,5"
                            BorderThickness="1" BorderBrush="#30363d" Margin="0,0,0,10" Cursor="Hand"/>

                    <Button Content="📋 复制私钥文件" Click="CopyKeyFile_Click"
                            Background="#21262d" Foreground="#d29922" Padding="10,5"
                            BorderThickness="1" BorderBrush="#30363d" Margin="0,0,0,10" Cursor="Hand"/>

                    <Button Content="🔄 更换密钥（备份→生成→部署→验证）" Click="ReplaceKey_Click"
                            Background="#21262d" Foreground="#ff7b72" Padding="10,5"
                            BorderThickness="1" BorderBrush="#30363d" Margin="0,10,0,0" Cursor="Hand"/>
                </StackPanel>
            </Border>
            <!-- 卡片3：二维码（占位） -->
            <Border Grid.Row="2" Padding="20">
                <StackPanel>
                    <TextBlock Text="📱 手机扫码导入" Foreground="#8b949e" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#8b949e" FontSize="11" Margin="0,0,0,15">
                        使用 Termius、JuiceSSH 扫码可直接导入。请确保周围无人窥视！
                    </TextBlock>
                    <!-- 这里预留二维码位置 -->
                    <Border Background="White" Width="120" Height="120" CornerRadius="8" HorizontalAlignment="Center">
                        <TextBlock Text="二维码占位区" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
